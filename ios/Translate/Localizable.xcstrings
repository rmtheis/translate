    "This pair is one-way only.": {
      "comment": "Error shown when the user taps swap on a pair that doesn't have a backward direction (e.g. mkd→eng has no eng→mkd).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
