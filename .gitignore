*.iml
.DS_Store
.gradle
/.idea

# ---------------------------------------------------------------------------
# Shared
# ---------------------------------------------------------------------------
# Flat staging dir populated by <platform>/native/prep-pair.sh on dev/CI.
pair-jars/
# Python bytecode from scripts/*.py
__pycache__/

# ---------------------------------------------------------------------------
# Android
# ---------------------------------------------------------------------------
/android/local.properties
/android/captures
/android/build
android/build/
android/.externalNativeBuild
# Native binaries + shared libs populated by scripts/install-natives-android.sh
android/app/src/main/jniLibs/
# Legacy flat layout, now replaced by pair_<code>/src/main/assets/ packs.
android/app/src/main/assets/pairs/
# Upload keystore is CI-only (decoded from PLAY_UPLOAD_KEYSTORE_BASE64 secret).
android/app/upload.keystore
# Java heap-dump snapshots from OOM diagnostic runs.
*.hprof

# ---------------------------------------------------------------------------
# Android NDK (android/native/)
# ---------------------------------------------------------------------------
android/native/build/
android/native/out/
android/native/deps/
# upstream sources (cloned at build time)
android/native/apertium/
android/native/apertium-anaphora/
android/native/apertium-lex-tools/
android/native/apertium-recursive/
android/native/apertium-separable/
android/native/cg3/
android/native/hfst/
android/native/lttoolbox/
android/native/openfst/
android/native/test-hello/build/

# ---------------------------------------------------------------------------
# iOS
# ---------------------------------------------------------------------------
# Xcode project is generated by xcodegen from ios/project.yml.
ios/Translate.xcodeproj/
# Staged pair folders (populated by scripts/stage-pair-odrs.sh).
ios/PairResources/
# DerivedData / Pods / xcuserdata
ios/**/build/
ios/**/xcuserdata/
ios/**/.swiftpm/

# ---------------------------------------------------------------------------
# iOS xcframework build (ios/native/)
# ---------------------------------------------------------------------------
ios/native/build/
ios/native/out/
ios/native/deps/
ios/native/ApertiumCore.xcframework/
# upstream sources (cloned at build time)
ios/native/apertium/
ios/native/apertium-anaphora/
ios/native/apertium-lex-tools/
ios/native/apertium-recursive/
ios/native/apertium-separable/
ios/native/cg3/
ios/native/hfst/
ios/native/lttoolbox/
ios/native/openfst/
# Local test drivers used during the iOS port — reusable but not part
# of the release surface.
ios/native/test-hola/
ios/native/test-sme-nob/
